// This is your Prisma schema file
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum InventoryTransactionType {
  IMPORT
  EXPORT
  ADJUST
  TRANSFER
}

enum CustomerType {
  RETAIL
  WHOLESALE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPING
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  COD
  MOMO
  ZALOPAY
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum SyncDirection {
  PUSH
  PULL
}

enum SyncStatus {
  SUCCESS
  FAILED
  PENDING
}

// ─── RBAC ───────────────────────────────────────────────────────────────────

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  displayName String
  description String?
  isSystem    Boolean      @default(false)
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("roles")
}

model Permission {
  id     Int    @id @default(autoincrement())
  module String
  action String
  roleId Int
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([module, action, roleId])
  @@map("permissions")
}

// ─── Users ──────────────────────────────────────────────────────────────────

model User {
  id                  String            @id @default(uuid())
  email               String            @unique
  password            String
  name                String
  phone               String?
  avatar              String?
  roleId              Int
  role                Role              @relation(fields: [roleId], references: [id])
  status              UserStatus        @default(ACTIVE)
  mustChangePassword  Boolean           @default(false)
  lastLoginAt         DateTime?
  lastLoginIp         String?
  createdBy           String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  activityLogs        UserActivityLog[]
  orders              Order[]           @relation("CreatedByUser")

  @@map("users")
}

model UserActivityLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  module    String
  detail    Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("user_activity_logs")
}

// ─── Categories ─────────────────────────────────────────────────────────────

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  code      String?    @unique
  parentId  Int?
  parent    Category?  @relation("CategorySelf", fields: [parentId], references: [id])
  children  Category[] @relation("CategorySelf")
  nhanhId   String?    @unique
  products  Product[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("categories")
}

// ─── Products ───────────────────────────────────────────────────────────────

model Product {
  id               Int              @id @default(autoincrement())
  name             String
  code             String           @unique
  barcode          String?          @unique
  categoryId       Int?
  category         Category?        @relation(fields: [categoryId], references: [id])
  unit             String           @default("Cái")
  costPrice        Decimal          @default(0) @db.Decimal(18, 2)
  salePrice        Decimal          @default(0) @db.Decimal(18, 2)
  weight           Decimal?         @db.Decimal(10, 3)
  description      String?
  images           Json             @default("[]")
  status           ProductStatus    @default(ACTIVE)
  nhanhId          String?          @unique
  nhanhData        Json?
  variants         ProductVariant[]
  inventoryItems   InventoryItem[]
  orderItems       OrderItem[]
  transactions     InventoryTransaction[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([code])
  @@index([nhanhId])
  @@map("products")
}

model ProductVariant {
  id          Int      @id @default(autoincrement())
  productId   Int
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String
  sku         String   @unique
  barcode     String?
  costPrice   Decimal  @default(0) @db.Decimal(18, 2)
  salePrice   Decimal  @default(0) @db.Decimal(18, 2)
  attributes  Json     @default("{}")
  nhanhId     String?  @unique
  inventoryItems InventoryItem[]
  orderItems  OrderItem[]
  transactions InventoryTransaction[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@map("product_variants")
}

// ─── Warehouses & Inventory ─────────────────────────────────────────────────

model Warehouse {
  id             Int             @id @default(autoincrement())
  name           String
  code           String          @unique
  address        String?
  isDefault      Boolean         @default(false)
  nhanhId        String?         @unique
  inventoryItems InventoryItem[]
  transactions   InventoryTransaction[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("warehouses")
}

model InventoryItem {
  id          Int              @id @default(autoincrement())
  productId   Int
  product     Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId   Int?
  variant     ProductVariant?  @relation(fields: [variantId], references: [id])
  warehouseId Int
  warehouse   Warehouse        @relation(fields: [warehouseId], references: [id])
  quantity    Int              @default(0)
  minQuantity Int              @default(0)
  maxQuantity Int?
  updatedAt   DateTime         @updatedAt

  @@unique([productId, variantId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
  @@map("inventory_items")
}

model InventoryTransaction {
  id            String                   @id @default(uuid())
  type          InventoryTransactionType
  productId     Int
  product       Product                  @relation(fields: [productId], references: [id])
  variantId     Int?
  variant       ProductVariant?          @relation(fields: [variantId], references: [id])
  warehouseId   Int
  warehouse     Warehouse                @relation(fields: [warehouseId], references: [id])
  quantity      Int
  previousQty   Int
  newQty        Int
  note          String?
  referenceId   String?
  referenceType String?
  createdBy     String?
  createdAt     DateTime                 @default(now())

  @@index([productId])
  @@index([warehouseId])
  @@index([createdAt])
  @@map("inventory_transactions")
}

// ─── Customers ──────────────────────────────────────────────────────────────

model Customer {
  id          String       @id @default(uuid())
  code        String       @unique
  name        String
  phone       String?      @unique
  email       String?
  address     String?
  gender      String?
  birthday    DateTime?
  type        CustomerType @default(RETAIL)
  totalOrders Int          @default(0)
  totalSpent  Decimal      @default(0) @db.Decimal(18, 2)
  nhanhId     String?      @unique
  orders      Order[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([phone])
  @@index([nhanhId])
  @@map("customers")
}

// ─── Orders ─────────────────────────────────────────────────────────────────

model Order {
  id              String        @id @default(uuid())
  code            String        @unique
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  status          OrderStatus   @default(PENDING)
  subtotal        Decimal       @default(0) @db.Decimal(18, 2)
  discount        Decimal       @default(0) @db.Decimal(18, 2)
  shippingFee     Decimal       @default(0) @db.Decimal(18, 2)
  tax             Decimal       @default(0) @db.Decimal(18, 2)
  total           Decimal       @default(0) @db.Decimal(18, 2)
  paymentMethod   PaymentMethod @default(CASH)
  paymentStatus   PaymentStatus @default(UNPAID)
  shippingAddress Json?
  note            String?
  nhanhId         String?       @unique
  nhanhStatus     String?
  nhanhData       Json?
  createdById     String?
  createdBy       User?         @relation("CreatedByUser", fields: [createdById], references: [id])
  items           OrderItem[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([customerId])
  @@index([nhanhId])
  @@map("orders")
}

model OrderItem {
  id          String          @id @default(uuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   Int
  product     Product         @relation(fields: [productId], references: [id])
  variantId   Int?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  productName String
  variantName String?
  sku         String
  quantity    Int
  unitPrice   Decimal         @db.Decimal(18, 2)
  discount    Decimal         @default(0) @db.Decimal(18, 2)
  total       Decimal         @db.Decimal(18, 2)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ─── Nhanh.vn Accounts ──────────────────────────────────────────────────────

model NhanhAccount {
  id            Int            @id @default(autoincrement())
  name          String
  businessId    String
  appId         String
  accessToken   String
  webhookSecret String?
  isActive      Boolean        @default(true)
  lastSyncAt    DateTime?
  syncInterval  Int            @default(30)
  note          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  syncLogs      NhanhSyncLog[]

  @@map("nhanh_accounts")
}

// ─── Nhanh.vn Sync ──────────────────────────────────────────────────────────

model NhanhSyncLog {
  id         String        @id @default(uuid())
  accountId  Int?
  account    NhanhAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  type       String
  direction  SyncDirection
  status     SyncStatus
  payload    Json?
  response   Json?
  error      String?
  createdAt  DateTime      @default(now())

  @@index([accountId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("nhanh_sync_logs")
}

// ─── Refresh Tokens ─────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

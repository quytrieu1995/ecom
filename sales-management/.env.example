# ================================
# App Configuration
# ================================
NODE_ENV=production
PORT=4000
JWT_SECRET=change_this_to_a_very_long_random_secret_min_64_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_also_very_long_random
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ================================
# Database (PostgreSQL)
# ================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=salesdb
DB_USER=salesuser
DB_PASSWORD=change_this_strong_password

# Prisma DATABASE_URL (auto-built from above in config/database.js)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public

# ================================
# Redis
# ================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password

# ================================
# Nhanh.vn Integration
# ================================
NHANHVN_API_URL=https://api.nhanh.vn
NHANHVN_APP_ID=your_app_id_here
NHANHVN_BUSINESS_ID=your_business_id_here
NHANHVN_ACCESS_TOKEN=your_access_token_here
NHANHVN_SECRET_KEY=your_webhook_hmac_secret_here
NHANHVN_WEBHOOK_URL=https://ql.thuanchay.vn/webhooks/nhanhvn

# ================================
# Sync Intervals (minutes)
# ================================
SYNC_PRODUCTS_INTERVAL=30
SYNC_ORDERS_INTERVAL=15
SYNC_INVENTORY_INTERVAL=60

# ================================
# Domain & Frontend
# ================================
NEXT_PUBLIC_APP_URL=https://ql.thuanchay.vn
NEXT_PUBLIC_API_URL=https://ql.thuanchay.vn/api/v1

# ================================
# Admin Seed
# ================================
ADMIN_EMAIL=admin@thuanchay.vn
ADMIN_PASSWORD=Admin@2024!

# ================================
# Logging
# ================================
LOG_LEVEL=info
